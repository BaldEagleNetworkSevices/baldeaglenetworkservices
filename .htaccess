Options -Indexes
DirectoryIndex index.php
ErrorDocument 404 /404.php

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://baldeaglenetworkservices.com%{REQUEST_URI} [R=301,L]
  RewriteCond %{HTTP_HOST} !^baldeaglenetworkservices\.com$ [NC]
  RewriteRule ^ https://baldeaglenetworkservices.com%{REQUEST_URI} [R=301,L]

  RewriteRule ^test\.php$ - [G,L,NC]
  RewriteRule ^(?:app|deploy|docs|storage|systemd)(?:/|$) - [F,L,NC]
  RewriteRule \.(?:live|prod|md|sh|py)$ - [F,L,NC]
</IfModule>

<Files "robots.txt">
  SetHandler application/x-httpd-php
</Files>

<Files "sitemap.xml">
  SetHandler application/x-httpd-php
</Files>
