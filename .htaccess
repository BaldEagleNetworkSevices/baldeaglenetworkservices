Options -Indexes
Options -MultiViews
DirectoryIndex index.php
ErrorDocument 404 /404.php

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^test\.php$ - [G,L,NC]
  RewriteRule ^(?:app|deploy|docs|storage|systemd)(?:/|$) - [F,L,NC]
  RewriteRule \.(?:live|prod|md|sh|py)$ - [F,L,NC]

  RewriteRule ^microsoft-365-services(?:\.php)?$ /recovery-assessment [R=301,L,NC,QSA]
  RewriteRule ^microsoft-365-support-salt-lake-city(?:\.php)?$ /recovery-assessment [R=301,L,NC,QSA]
  RewriteRule ^managed-it-services(?:\.php)?$ /monthly-it-support-plans [R=301,L,NC,QSA]
  RewriteRule ^one-off-it-projects(?:\.php)?$ /recovery-assessment [R=301,L,NC,QSA]
  RewriteRule ^network-cabling-wifi(?:\.php)?$ /recovery-assessment [R=301,L,NC,QSA]
  RewriteRule ^it-services-salt-lake-city(?:\.php)?$ /recovery-assessment [R=301,L,NC,QSA]

  RewriteCond %{HTTP_HOST} ^(?:baldeaglenetworkservices\.com|www\.baldeaglenetworkservices\.com)$ [NC]
  RewriteCond %{THE_REQUEST} \s/+index\.php(?:[?\s]|$) [NC]
  RewriteRule ^index\.php$ / [R=301,L,QSA]

  RewriteCond %{HTTP_HOST} ^(?:baldeaglenetworkservices\.com|www\.baldeaglenetworkservices\.com)$ [NC]
  RewriteCond %{THE_REQUEST} \s/+sitemap\.php(?:[?\s]|$) [NC]
  RewriteRule ^sitemap\.php$ /sitemap.xml [R=301,L,QSA]

  RewriteCond %{HTTP_HOST} ^(?:baldeaglenetworkservices\.com|www\.baldeaglenetworkservices\.com)$ [NC]
  RewriteCond %{THE_REQUEST} \s/+robots\.php(?:[?\s]|$) [NC]
  RewriteRule ^robots\.php$ /robots.txt [R=301,L,QSA]

  RewriteCond %{HTTP_HOST} ^(?:baldeaglenetworkservices\.com|www\.baldeaglenetworkservices\.com)$ [NC]
  RewriteCond %{THE_REQUEST} \s/+landing/([A-Za-z0-9-]+)\.php(?:[?\s]|$) [NC]
  RewriteRule ^landing/([A-Za-z0-9-]+)\.php$ /landing/$1 [R=301,L,QSA]

  RewriteCond %{HTTP_HOST} ^(?:baldeaglenetworkservices\.com|www\.baldeaglenetworkservices\.com)$ [NC]
  RewriteCond %{THE_REQUEST} \s/+([A-Za-z0-9-]+)\.php(?:[?\s]|$) [NC]
  RewriteCond %1 !^404$ [NC]
  RewriteRule ^([A-Za-z0-9-]+)\.php$ /$1 [R=301,L,QSA]

  RewriteCond %{HTTP_HOST} ^(?:baldeaglenetworkservices\.com|www\.baldeaglenetworkservices\.com)$ [NC]
  RewriteCond %{THE_REQUEST} \s/+([A-Za-z0-9-]+)/+(?:[?\s]|$) [NC]
  RewriteRule ^([A-Za-z0-9-]+)/+$ /$1 [R=301,L,QSA]

  RewriteCond %{HTTP_HOST} ^(?:baldeaglenetworkservices\.com|www\.baldeaglenetworkservices\.com)$ [NC]
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME}.php -f
  RewriteRule ^landing/([A-Za-z0-9-]+)/?$ landing/$1.php [L]

  RewriteRule ^sitemap\.xml$ sitemap.php [L]
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME}.php -f
  RewriteRule ^([A-Za-z0-9-]+)/?$ $1.php [L]
</IfModule>
